# Backend API
VITE_API_BASE_URL=http://localhost:4000/api

# Firebase client config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# App mode
# demo | real
VITE_APP_MODE=demo

# Billing debug details in Settings/Paywall
# true | false
VITE_SHOW_BILLING_DEBUG=false

# Analytics
# off | ga4
VITE_ANALYTICS_MODE=off
VITE_GA_MEASUREMENT_ID=

# Optional outbox sync endpoint
VITE_OUTBOX_SYNC_ENDPOINT=

# Billing
# mock_provider | api_contract
VITE_BILLING_PROVIDER_MODE=mock_provider
VITE_BILLING_PROVIDER_LABEL=Mock provider

# If you have a shared billing API base, the app will derive:
# - /checkout
# - /portal
# - /restore
# - /entitlements
VITE_BILLING_API_BASE=

# Optional explicit billing endpoints
VITE_BILLING_CHECKOUT_ENDPOINT=
VITE_BILLING_PORTAL_ENDPOINT=
VITE_BILLING_RESTORE_ENDPOINT=
VITE_BILLING_ENTITLEMENT_SYNC_ENDPOINT=
